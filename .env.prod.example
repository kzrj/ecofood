# Скопируйте в .env на боевом сервере и подставьте реальные значения.

# --- MongoDB ---
# Если задать пользователя/пароль — mongo поднимется с включённой авторизацией,
# и MONGODB_URI ниже должен использовать эти же креды.
MONGO_INITDB_ROOT_USERNAME=ecofood
MONGO_INITDB_ROOT_PASSWORD=change_me_strong_password

# --- API ---
# Без авторизации:
# MONGODB_URI=mongodb://mongo:27017
# С авторизацией (как выше):
MONGODB_URI=mongodb://ecofood:change_me_strong_password@mongo:27017/?authSource=admin
MONGODB_DB_NAME=ecofood

# --- Web ---
# Порт хоста, на котором слушает nginx (внутри контейнера всегда 80).
WEB_PORT=80
